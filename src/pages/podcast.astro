---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="The Daily Digest | News Podcast" description="Your personalized 10-minute news podcast covering AI, Apple, Autodesk, and your favorite sports teams" />
		<style>
			.podcast-header {
				text-align: center;
				margin-bottom: 2rem;
			}
			.podcast-header h1 {
				font-size: 2.4rem;
				margin-bottom: 0.25rem;
			}
			.podcast-header .subtitle {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				margin: 0;
			}

			/* Category selection */
			.categories {
				background: rgba(var(--gray-light), 0.5);
				border-radius: 12px;
				padding: 1.5rem;
				margin-bottom: 1.5rem;
			}
			.categories h3 {
				margin: 0 0 1rem 0;
				font-size: 1.1rem;
			}
			.category-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 0.75rem;
			}
			.category-grid label {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				cursor: pointer;
				padding: 0.5rem 0.75rem;
				border-radius: 8px;
				background: white;
				border: 2px solid rgb(var(--gray-light));
				transition: all 0.15s ease;
				font-size: 0.95rem;
				user-select: none;
			}
			.category-grid label:hover {
				border-color: var(--accent);
			}
			.category-grid label:has(input:checked) {
				border-color: var(--accent);
				background: rgba(35, 55, 255, 0.05);
			}
			.category-grid input[type="checkbox"] {
				accent-color: var(--accent);
				width: 18px;
				height: 18px;
			}

			/* Generate button */
			.generate-btn {
				display: block;
				width: 100%;
				padding: 1rem;
				font-size: 1.15rem;
				font-weight: 700;
				font-family: 'Atkinson', sans-serif;
				background: var(--accent);
				color: white;
				border: none;
				border-radius: 10px;
				cursor: pointer;
				transition: all 0.15s ease;
			}
			.generate-btn:hover:not(:disabled) {
				background: var(--accent-dark);
				transform: translateY(-1px);
			}
			.generate-btn:disabled {
				opacity: 0.5;
				cursor: not-allowed;
			}

			/* Loading */
			.loading {
				text-align: center;
				padding: 3rem 1rem;
			}
			.spinner {
				width: 48px;
				height: 48px;
				border: 4px solid rgb(var(--gray-light));
				border-top-color: var(--accent);
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
				margin: 0 auto 1rem;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.loading p {
				margin: 0.25rem 0;
				color: rgb(var(--gray-dark));
			}
			.loading .sub {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}

			/* Error */
			.error-msg {
				background: #fef2f2;
				border: 1px solid #fca5a5;
				color: #991b1b;
				padding: 1rem 1.25rem;
				border-radius: 8px;
				margin-bottom: 1rem;
			}

			/* Player */
			.player {
				margin-top: 2rem;
			}
			.player h2 {
				font-size: 1.5rem;
				margin-bottom: 0.25rem;
			}
			.player .meta {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin: 0 0 1.25rem 0;
			}

			/* Controls bar */
			.controls {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				background: rgb(var(--black));
				padding: 0.75rem 1rem;
				border-radius: 12px;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}
			.control-btn {
				width: 44px;
				height: 44px;
				border: none;
				border-radius: 50%;
				background: var(--accent);
				color: white;
				font-size: 1.1rem;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
				transition: background 0.15s;
			}
			.control-btn:hover {
				background: var(--accent-dark);
			}
			.control-btn.stop {
				background: rgba(255,255,255,0.15);
			}
			.control-btn.stop:hover {
				background: rgba(255,255,255,0.25);
			}

			/* Progress */
			.progress-container {
				flex: 1;
				min-width: 150px;
			}
			.progress-bar {
				height: 6px;
				background: rgba(255,255,255,0.15);
				border-radius: 3px;
				overflow: hidden;
				cursor: pointer;
			}
			.progress-fill {
				height: 100%;
				background: var(--accent);
				width: 0%;
				transition: width 0.3s ease;
				border-radius: 3px;
			}
			.progress-time {
				color: rgba(255,255,255,0.6);
				font-size: 0.75rem;
				margin-top: 0.25rem;
			}

			/* Speed & voice controls */
			.playback-options {
				display: flex;
				gap: 0.5rem;
				align-items: center;
			}
			.playback-options label {
				color: rgba(255,255,255,0.6);
				font-size: 0.8rem;
			}
			.playback-options select {
				background: rgba(255,255,255,0.1);
				color: white;
				border: 1px solid rgba(255,255,255,0.2);
				border-radius: 6px;
				padding: 0.3rem 0.4rem;
				font-size: 0.8rem;
				font-family: 'Atkinson', sans-serif;
				cursor: pointer;
			}
			.playback-options select option {
				background: rgb(var(--black));
				color: white;
			}

			/* Script display */
			.script-container {
				max-height: 500px;
				overflow-y: auto;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.5rem;
				background: white;
				scroll-behavior: smooth;
			}
			.paragraph {
				padding: 0.75rem 1rem;
				border-radius: 8px;
				margin-bottom: 0.5rem;
				line-height: 1.6;
				font-size: 1rem;
				cursor: pointer;
				transition: all 0.2s ease;
				border-left: 3px solid transparent;
			}
			.paragraph:hover {
				background: rgba(var(--gray-light), 0.4);
			}
			.paragraph.active {
				background: rgba(35, 55, 255, 0.06);
				border-left-color: var(--accent);
			}
			.paragraph.spoken {
				opacity: 0.5;
			}

			/* Actions */
			.actions {
				display: flex;
				gap: 0.75rem;
				margin-top: 1rem;
			}
			.action-btn {
				padding: 0.6rem 1.2rem;
				font-size: 0.9rem;
				font-family: 'Atkinson', sans-serif;
				border: 2px solid rgb(var(--gray-light));
				background: white;
				color: rgb(var(--gray-dark));
				border-radius: 8px;
				cursor: pointer;
				transition: all 0.15s;
			}
			.action-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
			}

			.hidden { display: none !important; }

			@media (max-width: 720px) {
				.category-grid {
					grid-template-columns: 1fr;
				}
				.controls {
					gap: 0.5rem;
					padding: 0.5rem 0.75rem;
				}
				.playback-options {
					width: 100%;
					justify-content: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Header -->
			<section class="podcast-header">
				<h1>The Daily Digest</h1>
				<p class="subtitle">Your personalized 10-minute news podcast, generated on demand</p>
			</section>

			<!-- Category Selection -->
			<section class="categories">
				<h3>Select your topics</h3>
				<div class="category-grid">
					<label>
						<input type="checkbox" name="category" value="ai" checked />
						AI & Claude Code
					</label>
					<label>
						<input type="checkbox" name="category" value="apple" checked />
						Apple
					</label>
					<label>
						<input type="checkbox" name="category" value="autodesk" checked />
						Graitec & Autodesk
					</label>
					<label>
						<input type="checkbox" name="category" value="detroit_sports" checked />
						Detroit Sports
					</label>
					<label>
						<input type="checkbox" name="category" value="college_sports" checked />
						College Sports
					</label>
				</div>
			</section>

			<button id="generate-btn" class="generate-btn">Generate My Podcast</button>

			<!-- Loading State -->
			<section id="loading" class="loading hidden">
				<div class="spinner"></div>
				<p>Fetching the latest news and writing your podcast...</p>
				<p class="sub">This usually takes 20-40 seconds</p>
			</section>

			<!-- Error State -->
			<div id="error" class="error-msg hidden"></div>

			<!-- Podcast Player -->
			<section id="player" class="player hidden">
				<h2 id="podcast-title"></h2>
				<p id="podcast-meta" class="meta"></p>

				<div class="controls">
					<button id="play-btn" class="control-btn" title="Play / Pause" aria-label="Play">
						<svg id="play-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
						<svg id="pause-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="5" y="3" width="4" height="18"/><rect x="15" y="3" width="4" height="18"/></svg>
					</button>
					<button id="stop-btn" class="control-btn stop" title="Stop" aria-label="Stop">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2"/></svg>
					</button>

					<div class="progress-container">
						<div class="progress-bar" id="progress-bar">
							<div id="progress-fill" class="progress-fill"></div>
						</div>
						<div class="progress-time" id="progress-time">Paragraph 0 / 0</div>
					</div>

					<div class="playback-options">
						<label for="speed">Speed</label>
						<select id="speed">
							<option value="0.75">0.75x</option>
							<option value="0.9">0.9x</option>
							<option value="1" selected>1x</option>
							<option value="1.15">1.15x</option>
							<option value="1.3">1.3x</option>
							<option value="1.5">1.5x</option>
							<option value="2">2x</option>
						</select>
						<label for="voice">Voice</label>
						<select id="voice"></select>
					</div>
				</div>

				<div class="script-container" id="script-container">
					<div id="script"></div>
				</div>

				<div class="actions">
					<button id="download-btn" class="action-btn">Download Script</button>
					<button id="copy-btn" class="action-btn">Copy to Clipboard</button>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			// ---- Elements ----
			const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
			const loadingEl = document.getElementById('loading')!;
			const errorEl = document.getElementById('error')!;
			const playerEl = document.getElementById('player')!;
			const playBtn = document.getElementById('play-btn')!;
			const stopBtn = document.getElementById('stop-btn')!;
			const playIcon = document.getElementById('play-icon')!;
			const pauseIcon = document.getElementById('pause-icon')!;
			const progressFill = document.getElementById('progress-fill')!;
			const progressTime = document.getElementById('progress-time')!;
			const progressBar = document.getElementById('progress-bar')!;
			const speedSelect = document.getElementById('speed') as HTMLSelectElement;
			const voiceSelect = document.getElementById('voice') as HTMLSelectElement;
			const scriptEl = document.getElementById('script')!;
			const scriptContainer = document.getElementById('script-container')!;
			const titleEl = document.getElementById('podcast-title')!;
			const metaEl = document.getElementById('podcast-meta')!;
			const downloadBtn = document.getElementById('download-btn')!;
			const copyBtn = document.getElementById('copy-btn')!;

			// ---- State ----
			let podcastScript = '';
			let paragraphs: string[] = [];
			let currentIndex = -1;
			let isPlaying = false;
			let isPaused = false;

			// ---- Voice loading ----
			function loadVoices() {
				const voices = speechSynthesis.getVoices();
				if (voices.length === 0) return;

				voiceSelect.innerHTML = '';
				const english = voices.filter(v => v.lang.startsWith('en'));
				const sorted = [...english, ...voices.filter(v => !v.lang.startsWith('en'))];

				let defaultIndex = 0;
				sorted.forEach((voice, i) => {
					const opt = document.createElement('option');
					opt.value = voices.indexOf(voice).toString();
					opt.textContent = `${voice.name} (${voice.lang})`;
					voiceSelect.appendChild(opt);
					if (voice.default && voice.lang.startsWith('en')) defaultIndex = i;
				});
				voiceSelect.selectedIndex = defaultIndex;
			}
			speechSynthesis.onvoiceschanged = loadVoices;
			loadVoices();

			// ---- Generate ----
			generateBtn.addEventListener('click', async () => {
				const checked = document.querySelectorAll<HTMLInputElement>('input[name="category"]:checked');
				const categories = Array.from(checked).map(el => el.value);

				if (categories.length === 0) {
					showError('Please select at least one topic.');
					return;
				}

				stopPlayback();
				hideError();
				playerEl.classList.add('hidden');
				loadingEl.classList.remove('hidden');
				generateBtn.disabled = true;

				try {
					const res = await fetch('/api/podcast', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ categories }),
					});
					const data = await res.json();

					if (!res.ok || data.error) {
						showError(data.error || 'Failed to generate podcast.');
						return;
					}

					podcastScript = data.script;
					paragraphs = podcastScript.split('\n\n').filter((p: string) => p.trim());

					titleEl.textContent = data.title;
					metaEl.textContent = `${data.storiesCount} stories \u00B7 ${data.categories.join(', ')} \u00B7 ~${data.estimatedMinutes} min \u00B7 ${paragraphs.length} paragraphs`;

					renderScript();
					playerEl.classList.remove('hidden');

				} catch {
					showError('Network error — please check your connection and try again.');
				} finally {
					loadingEl.classList.add('hidden');
					generateBtn.disabled = false;
				}
			});

			// ---- Script rendering ----
			function renderScript() {
				scriptEl.innerHTML = '';
				paragraphs.forEach((text, i) => {
					const div = document.createElement('div');
					div.className = 'paragraph';
					div.dataset.index = i.toString();
					div.textContent = text;
					div.addEventListener('click', () => {
						stopPlayback();
						playFrom(i);
					});
					scriptEl.appendChild(div);
				});
				updateProgress();
			}

			// ---- Playback ----
			function playFrom(index: number) {
				currentIndex = index;
				isPlaying = true;
				isPaused = false;
				showPauseIcon();
				speakParagraph(index);
			}

			function speakParagraph(index: number) {
				if (index >= paragraphs.length || !isPlaying) {
					isPlaying = false;
					isPaused = false;
					currentIndex = paragraphs.length;
					showPlayIcon();
					updateProgress();
					return;
				}

				currentIndex = index;
				highlightParagraph(index);
				updateProgress();

				const utter = new SpeechSynthesisUtterance(paragraphs[index]);
				utter.rate = parseFloat(speedSelect.value);

				const voiceIdx = parseInt(voiceSelect.value);
				const voices = speechSynthesis.getVoices();
				if (!isNaN(voiceIdx) && voices[voiceIdx]) {
					utter.voice = voices[voiceIdx];
				}

				utter.onend = () => {
					if (isPlaying && !isPaused) {
						speakParagraph(index + 1);
					}
				};

				utter.onerror = (e) => {
					if ((e as any).error !== 'canceled' && (e as any).error !== 'interrupted') {
						console.error('TTS error:', e);
					}
				};

				speechSynthesis.speak(utter);
			}

			function highlightParagraph(index: number) {
				const all = scriptEl.querySelectorAll('.paragraph');
				all.forEach((el, i) => {
					el.classList.toggle('active', i === index);
					el.classList.toggle('spoken', i < index);
				});

				const active = scriptEl.querySelector('.paragraph.active') as HTMLElement;
				if (active) {
					const containerRect = scriptContainer.getBoundingClientRect();
					const activeRect = active.getBoundingClientRect();
					const offset = activeRect.top - containerRect.top - containerRect.height / 3;
					scriptContainer.scrollTop += offset;
				}
			}

			function updateProgress() {
				const total = paragraphs.length;
				const current = Math.max(0, currentIndex);
				const fraction = total > 0 ? current / total : 0;
				progressFill.style.width = `${fraction * 100}%`;
				progressTime.textContent = `Paragraph ${current} / ${total}`;
			}

			// ---- Controls ----
			playBtn.addEventListener('click', () => {
				if (isPlaying && !isPaused) {
					speechSynthesis.pause();
					isPaused = true;
					showPlayIcon();
				} else if (isPaused) {
					speechSynthesis.resume();
					isPaused = false;
					showPauseIcon();
				} else {
					const start = currentIndex >= 0 && currentIndex < paragraphs.length ? currentIndex : 0;
					playFrom(start);
				}
			});

			stopBtn.addEventListener('click', stopPlayback);

			speedSelect.addEventListener('change', () => {
				if (isPlaying && !isPaused) {
					const idx = currentIndex;
					speechSynthesis.cancel();
					playFrom(idx);
				}
			});

			// Click on progress bar to jump
			progressBar.addEventListener('click', (e) => {
				const rect = progressBar.getBoundingClientRect();
				const fraction = (e.clientX - rect.left) / rect.width;
				const target = Math.floor(fraction * paragraphs.length);
				if (target >= 0 && target < paragraphs.length) {
					const wasPlaying = isPlaying;
					stopPlayback();
					if (wasPlaying) {
						playFrom(target);
					} else {
						currentIndex = target;
						highlightParagraph(target);
						updateProgress();
					}
				}
			});

			function stopPlayback() {
				speechSynthesis.cancel();
				isPlaying = false;
				isPaused = false;
				currentIndex = -1;
				showPlayIcon();
				scriptEl.querySelectorAll('.paragraph').forEach(el => {
					el.classList.remove('active', 'spoken');
				});
				updateProgress();
			}

			function showPlayIcon() {
				playIcon.classList.remove('hidden');
				pauseIcon.classList.add('hidden');
			}
			function showPauseIcon() {
				playIcon.classList.add('hidden');
				pauseIcon.classList.remove('hidden');
			}

			// ---- Download & Copy ----
			downloadBtn.addEventListener('click', () => {
				const blob = new Blob([podcastScript], { type: 'text/plain' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = `daily-digest-${new Date().toISOString().split('T')[0]}.txt`;
				document.body.appendChild(a);
				a.click();
				document.body.removeChild(a);
				URL.revokeObjectURL(url);
			});

			copyBtn.addEventListener('click', async () => {
				await navigator.clipboard.writeText(podcastScript);
				const original = copyBtn.textContent;
				copyBtn.textContent = 'Copied!';
				setTimeout(() => { copyBtn.textContent = original; }, 2000);
			});

			// ---- Helpers ----
			function showError(msg: string) {
				errorEl.textContent = msg;
				errorEl.classList.remove('hidden');
			}
			function hideError() {
				errorEl.classList.add('hidden');
			}
		</script>
	</body>
</html>
