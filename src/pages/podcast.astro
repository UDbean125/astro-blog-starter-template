---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Bryan's Daily Podcast" description="Your personalized 10-minute news podcast covering AI, Apple, Autodesk, and your favorite sports teams" />
		<style>
			.podcast-header { text-align: center; margin-bottom: 2rem; }
			.podcast-header h1 { font-size: 2.4rem; margin-bottom: 0.25rem; }
			.podcast-header .subtitle { color: rgb(var(--gray)); font-size: 1.1rem; margin: 0; }

			.categories, .voice-picker {
				background: rgba(var(--gray-light), 0.5);
				border-radius: 12px;
				padding: 1.5rem;
				margin-bottom: 1.5rem;
			}
			.categories h3, .voice-picker h3 { margin: 0 0 1rem 0; font-size: 1.1rem; }
			.category-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 0.75rem;
			}
			.category-grid label {
				display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
				padding: 0.5rem 0.75rem; border-radius: 8px; background: white;
				border: 2px solid rgb(var(--gray-light)); transition: all 0.15s ease;
				font-size: 0.95rem; user-select: none;
			}
			.category-grid label:hover { border-color: var(--accent); }
			.category-grid label:has(input:checked) { border-color: var(--accent); background: rgba(35, 55, 255, 0.05); }
			.category-grid input[type="checkbox"] { accent-color: var(--accent); width: 18px; height: 18px; }

			.voice-picker select {
				width: 100%; padding: 0.6rem 0.75rem; font-size: 1rem;
				font-family: 'Atkinson', sans-serif; border: 2px solid rgb(var(--gray-light));
				border-radius: 8px; background: white; cursor: pointer;
			}

			.generate-btn {
				display: block; width: 100%; padding: 1rem; font-size: 1.15rem;
				font-weight: 700; font-family: 'Atkinson', sans-serif; background: var(--accent);
				color: white; border: none; border-radius: 10px; cursor: pointer; transition: all 0.15s ease;
			}
			.generate-btn:hover:not(:disabled) { background: var(--accent-dark); transform: translateY(-1px); }
			.generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

			.loading { text-align: center; padding: 3rem 1rem; }
			.spinner {
				width: 48px; height: 48px; border: 4px solid rgb(var(--gray-light));
				border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite;
				margin: 0 auto 1rem;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.loading p { margin: 0.25rem 0; color: rgb(var(--gray-dark)); }
			.loading .sub { font-size: 0.9rem; color: rgb(var(--gray)); }

			.error-msg {
				background: #fef2f2; border: 1px solid #fca5a5; color: #991b1b;
				padding: 1rem 1.25rem; border-radius: 8px; margin-bottom: 1rem;
			}
			.success-msg {
				background: #f0fdf4; border: 1px solid #86efac; color: #166534;
				padding: 1rem 1.25rem; border-radius: 8px; margin-bottom: 1rem;
			}

			.player { margin-top: 2rem; }
			.player h2 { font-size: 1.5rem; margin-bottom: 0.25rem; }
			.player .meta { color: rgb(var(--gray)); font-size: 0.9rem; margin: 0 0 1.25rem 0; }

			.audio-container {
				background: rgb(var(--black)); border-radius: 12px;
				padding: 1.25rem; margin-bottom: 1.5rem;
			}
			.audio-container audio { width: 100%; height: 48px; border-radius: 8px; }
			.audio-status { color: rgba(255,255,255,0.6); font-size: 0.85rem; text-align: center; margin-top: 0.5rem; }

			.script-container {
				max-height: 500px; overflow-y: auto; border: 1px solid rgb(var(--gray-light));
				border-radius: 12px; padding: 1.5rem; background: white; scroll-behavior: smooth;
			}
			.script-text { line-height: 1.7; font-size: 1rem; white-space: pre-wrap; }

			.actions { display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap; }
			.action-btn {
				padding: 0.6rem 1.2rem; font-size: 0.9rem; font-family: 'Atkinson', sans-serif;
				border: 2px solid rgb(var(--gray-light)); background: white; color: rgb(var(--gray-dark));
				border-radius: 8px; cursor: pointer; transition: all 0.15s;
			}
			.action-btn:hover { border-color: var(--accent); color: var(--accent); }

			.voice-row { display: flex; gap: 0.75rem; align-items: center; }
			.voice-row select { flex: 1; }
			.preview-btn {
				padding: 0.6rem 1rem; font-size: 0.9rem; font-family: 'Atkinson', sans-serif;
				background: white; border: 2px solid rgb(var(--gray-light)); border-radius: 8px;
				cursor: pointer; transition: all 0.15s; white-space: nowrap;
			}
			.preview-btn:hover { border-color: var(--accent); color: var(--accent); }
			.preview-btn:disabled { opacity: 0.5; cursor: not-allowed; }

			.hidden { display: none !important; }

			@media (max-width: 720px) {
				.category-grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="podcast-header">
				<h1>Bryan's Daily Podcast</h1>
				<p class="subtitle">Your personalized 10-minute news podcast, generated on demand</p>
			</section>

			<section class="categories">
				<h3>Select your topics</h3>
				<div class="category-grid">
					<label><input type="checkbox" name="category" value="ai" checked /> AI & Claude Code</label>
					<label><input type="checkbox" name="category" value="apple" checked /> Apple</label>
					<label><input type="checkbox" name="category" value="autodesk" checked /> Graitec & Autodesk</label>
					<label><input type="checkbox" name="category" value="detroit_sports" checked /> Detroit Sports</label>
					<label><input type="checkbox" name="category" value="college_sports" checked /> College Sports</label>
				</div>
			</section>

			<section class="voice-picker">
				<h3>Choose a voice</h3>
				<div class="voice-row">
					<select id="voice"><option value="en-US-AndrewNeural">Andrew (Male, US)</option></select>
					<button id="preview-btn" class="preview-btn">Preview Voice</button>
				</div>
				<audio id="preview-audio" style="width:100%; margin-top:0.75rem; display:none;" controls></audio>
			</section>

			<button id="generate-btn" class="generate-btn">Generate My Podcast</button>

			<section id="loading" class="loading hidden">
				<div class="spinner"></div>
				<p id="loading-text">Starting...</p>
				<p class="sub" id="loading-sub"></p>
			</section>

			<div id="error" class="error-msg hidden"></div>
			<div id="success" class="success-msg hidden"></div>

			<section id="player" class="player hidden">
				<h2 id="podcast-title"></h2>
				<p id="podcast-meta" class="meta"></p>

				<div class="audio-container" id="audio-container">
					<audio id="audio-player" controls preload="auto"></audio>
					<div id="audio-status" class="audio-status"></div>
				</div>

				<div class="script-container">
					<div id="script" class="script-text"></div>
				</div>

				<div class="actions">
					<button id="download-audio-btn" class="action-btn">Download Audio (MP3)</button>
					<button id="download-btn" class="action-btn">Download Script</button>
					<button id="copy-btn" class="action-btn">Copy Script</button>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
			const loadingEl = document.getElementById('loading')!;
			const loadingText = document.getElementById('loading-text')!;
			const loadingSub = document.getElementById('loading-sub')!;
			const errorEl = document.getElementById('error')!;
			const successEl = document.getElementById('success')!;
			const playerEl = document.getElementById('player')!;
			const voiceSelect = document.getElementById('voice') as HTMLSelectElement;
			const audioPlayer = document.getElementById('audio-player') as HTMLAudioElement;
			const audioContainer = document.getElementById('audio-container')!;
			const audioStatus = document.getElementById('audio-status')!;
			const scriptEl = document.getElementById('script')!;
			const titleEl = document.getElementById('podcast-title')!;
			const metaEl = document.getElementById('podcast-meta')!;
			const downloadBtn = document.getElementById('download-btn')!;
			const downloadAudioBtn = document.getElementById('download-audio-btn')!;
			const copyBtn = document.getElementById('copy-btn')!;

			let podcastScript = '';
			let audioFilename = '';
			const previewBtn = document.getElementById('preview-btn') as HTMLButtonElement;
			const previewAudio = document.getElementById('preview-audio') as HTMLAudioElement;

			// Voice preview
			previewBtn.addEventListener('click', async () => {
				previewBtn.disabled = true;
				previewBtn.textContent = 'Loading...';
				previewAudio.style.display = 'none';
				try {
					const res = await fetch('/api/preview-voice', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ voice: voiceSelect.value }),
					});
					if (!res.ok) throw new Error();
					const blob = await res.blob();
					previewAudio.src = URL.createObjectURL(blob);
					previewAudio.style.display = 'block';
					previewAudio.play();
				} catch {
					showError('Voice preview failed. Try again.');
				} finally {
					previewBtn.disabled = false;
					previewBtn.textContent = 'Preview Voice';
				}
			});

			// Load voices
			fetch('/api/podcast').then(r => r.json()).then(voices => {
				if (!Array.isArray(voices)) return;
				voiceSelect.innerHTML = '';
				for (const v of voices) {
					const opt = document.createElement('option');
					opt.value = v.id;
					opt.textContent = v.name;
					voiceSelect.appendChild(opt);
				}
				voiceSelect.value = 'en-US-AndrewNeural';
			}).catch(() => {});

			// Generate — one button does everything
			generateBtn.addEventListener('click', async () => {
				const checked = document.querySelectorAll<HTMLInputElement>('input[name="category"]:checked');
				const categories = Array.from(checked).map(el => el.value);
				if (categories.length === 0) { showError('Please select at least one topic.'); return; }

				hideError(); hideSuccess();
				playerEl.classList.add('hidden');
				loadingEl.classList.remove('hidden');
				generateBtn.disabled = true;
				loadingText.textContent = 'Fetching news, writing script, generating audio...';
				loadingSub.textContent = 'This takes about 60-90 seconds — sit tight!';

				try {
					const res = await fetch('/api/podcast', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ categories, voice: voiceSelect.value }),
					});
					const data = await res.json();

					if (!res.ok || data.error) {
						showError(data.error || 'Failed to generate podcast.');
						return;
					}

					podcastScript = data.script;
					audioFilename = data.audioFilename;
					titleEl.textContent = data.title;
					metaEl.textContent = `${data.storiesCount} stories \u00B7 ${data.categories.join(', ')} \u00B7 ~${data.estimatedMinutes} min`;
					scriptEl.textContent = podcastScript;

					if (audioFilename) {
						audioPlayer.src = `/api/episodes/${audioFilename}`;
						audioContainer.classList.remove('hidden');
						downloadAudioBtn.classList.remove('hidden');
						audioStatus.textContent = '';
						if (data.published) {
							showSuccess('Episode published to your podcast feed! It will appear in Apple Podcasts shortly.');
						}
					} else {
						audioStatus.textContent = `Audio: ${data.audioError || 'Generation failed'}`;
						audioContainer.classList.remove('hidden');
						audioPlayer.classList.add('hidden');
						downloadAudioBtn.classList.add('hidden');
					}

					playerEl.classList.remove('hidden');

				} catch {
					showError('Network error — please check your connection and try again.');
				} finally {
					loadingEl.classList.add('hidden');
					generateBtn.disabled = false;
				}
			});

			// Download audio
			downloadAudioBtn.addEventListener('click', () => {
				if (!audioFilename) return;
				const a = document.createElement('a');
				a.href = `/api/episodes/${audioFilename}`;
				a.download = `bryans-daily-podcast-${new Date().toISOString().split('T')[0]}.mp3`;
				document.body.appendChild(a);
				a.click();
				document.body.removeChild(a);
			});

			// Download script
			downloadBtn.addEventListener('click', () => {
				const blob = new Blob([podcastScript], { type: 'text/plain' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = `bryans-daily-podcast-${new Date().toISOString().split('T')[0]}.txt`;
				document.body.appendChild(a);
				a.click();
				document.body.removeChild(a);
				URL.revokeObjectURL(url);
			});

			// Copy script
			copyBtn.addEventListener('click', async () => {
				await navigator.clipboard.writeText(podcastScript);
				copyBtn.textContent = 'Copied!';
				setTimeout(() => { copyBtn.textContent = 'Copy Script'; }, 2000);
			});

			function showError(msg: string) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); }
			function hideError() { errorEl.classList.add('hidden'); }
			function showSuccess(msg: string) { successEl.textContent = msg; successEl.classList.remove('hidden'); }
			function hideSuccess() { successEl.classList.add('hidden'); }
		</script>
	</body>
</html>
