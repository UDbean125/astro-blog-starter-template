---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section style="text-align: center; margin-bottom: 2.5rem;">
				<h1>Hennigan's Huddle</h1>
				<p style="font-size: 1.15rem; color: rgb(var(--gray)); max-width: 600px; margin: 0 auto;">
					Your personalized daily news podcast — AI, Apple, Autodesk, and your favorite sports teams, all in one 10-minute briefing.
				</p>
			</section>

			<section style="max-width: 640px; margin: 0 auto;">
				<div style="background: rgba(var(--gray-light), 0.5); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
					<h2 style="margin-top: 0; font-size: 1.3rem;">How It Works</h2>
					<p>
						Each episode is generated on demand. Pick the topics you care about, choose a voice, and hit generate.
						Claude writes a conversational script from the latest news, then text-to-speech turns it into a podcast episode
						you can stream or download — complete with an iTunes-ready RSS feed.
					</p>
				</div>

				<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
					<div style="background: rgba(var(--gray-light), 0.3); border-radius: 10px; padding: 1.25rem;">
						<strong>AI & Tech</strong>
						<p style="margin: 0.5rem 0 0; font-size: 0.9rem; color: rgb(var(--gray));">Claude Code, Anthropic, and the latest in AI capabilities</p>
					</div>
					<div style="background: rgba(var(--gray-light), 0.3); border-radius: 10px; padding: 1.25rem;">
						<strong>Apple</strong>
						<p style="margin: 0.5rem 0 0; font-size: 0.9rem; color: rgb(var(--gray));">iPhone, macOS, iOS, and Apple ecosystem news</p>
					</div>
					<div style="background: rgba(var(--gray-light), 0.3); border-radius: 10px; padding: 1.25rem;">
						<strong>Graitec & Autodesk</strong>
						<p style="margin: 0.5rem 0 0; font-size: 0.9rem; color: rgb(var(--gray));">BIM, Revit, and AEC industry updates</p>
					</div>
					<div style="background: rgba(var(--gray-light), 0.3); border-radius: 10px; padding: 1.25rem;">
						<strong>Sports</strong>
						<p style="margin: 0.5rem 0 0; font-size: 0.9rem; color: rgb(var(--gray));">Lions, Pistons, Red Wings, Tigers, Buckeyes, and Flyers</p>
					</div>
				</div>

				<a href="/podcast" style="display: block; text-align: center; padding: 1rem; font-size: 1.15rem; font-weight: 700; background: var(--accent); color: white; border-radius: 10px; text-decoration: none;">
					Generate My Podcast
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
