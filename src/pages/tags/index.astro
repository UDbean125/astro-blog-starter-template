---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Tags" pageTitle="Tags" subtitle="Browse by what matters to you." showViewSwitcher={false}>
	<section class="tag-cloud" data-cloud></section>
	<div class="empty-state" data-empty hidden>
		<h2>No tags yet</h2>
		<p class="mute big">Add tags when you save an article — they'll show up here.</p>
	</div>
</AppLayout>

<style>
.tag-cloud { display: flex; flex-wrap: wrap; gap: 10px; padding: 24px 0; }
.tag-cloud .tag {
	display: inline-flex; align-items: center; gap: 8px;
	background: var(--surface);
	border: 2px solid var(--border-strong);
	border-radius: var(--radius-pill);
	padding: 10px 18px;
	color: var(--text);
	font-weight: 700;
	transition: transform var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
	text-decoration: none;
}
.tag-cloud .tag:hover { background: var(--accent); color: var(--accent-contrast); border-color: transparent; transform: translateY(-2px); }
.tag-cloud .tag .count {
	background: var(--bg-sunken);
	color: var(--text-muted);
	font-weight: 700;
	font-size: var(--fs-sm);
	padding: 2px 8px;
	border-radius: 999px;
}
.tag-cloud .tag:hover .count { background: rgba(0,0,0,0.18); color: #fff; }
.empty-state { text-align: center; padding: 80px 20px; }
</style>

<script>
import { articles } from "../../lib/db";

const cloud = document.querySelector<HTMLElement>("[data-cloud]")!;
const empty = document.querySelector<HTMLElement>("[data-empty]")!;

(async () => {
	const all = await articles.all();
	const counts: Record<string, number> = {};
	for (const a of all) for (const t of a.tags) counts[t] = (counts[t] ?? 0) + 1;
	const tags = Object.entries(counts).sort(([,a], [,b]) => b - a);
	if (!tags.length) { empty.hidden = false; return; }
	cloud.innerHTML = tags.map(([t, n]) => `<a class="tag" href="/tags/${encodeURIComponent(t)}">${t} <span class="count">${n}</span></a>`).join("");
})();
</script>
