---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

interface Episode {
  id: string;
  title: string;
  description: string;
  showNotes?: string;
  script?: string;
  filename: string;
  fileSize: number;
  pubDate: string;
  duration: number;
  categories: string[];
}

const { id } = Astro.params;

const runtime = (Astro.locals as any).runtime;
const kv = runtime?.env?.EPISODES_KV;

let episode: Episode | undefined;
if (kv) {
  try {
    const episodes: Episode[] = (await kv.get('episodes', { type: 'json' })) || [];
    episode = episodes.find(ep => ep.id === id);
  } catch {}
}

if (!episode) {
  return Astro.redirect('/episodes');
}

function formatDuration(seconds: number): string {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
  });
}

const showNotes = episode.showNotes || episode.description;
const ogDescription = showNotes.slice(0, 200).replace(/\n/g, ' ');
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={episode.title} description={ogDescription} />
    <style>
      .ep-header { max-width: 720px; margin: 0 auto 2rem; }
      .ep-header h1 { font-size: 1.8rem; margin-bottom: 0.35rem; }
      .ep-meta { color: rgb(var(--gray)); font-size: 0.95rem; margin: 0 0 1rem 0; }

      .category-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1.5rem; }
      .category-tag {
        font-size: 0.8rem; background: rgba(var(--gray-light), 0.7);
        color: rgb(var(--gray-dark)); padding: 0.25rem 0.7rem; border-radius: 20px;
      }

      .audio-player {
        background: rgb(var(--black)); border-radius: 12px;
        padding: 1.25rem; margin-bottom: 2rem; max-width: 720px; margin-left: auto; margin-right: auto;
      }
      .audio-player audio { width: 100%; height: 48px; border-radius: 8px; }

      .show-notes {
        max-width: 720px; margin: 0 auto 2rem;
        line-height: 1.7; font-size: 1.05rem; white-space: pre-wrap;
      }
      .show-notes h2 { font-size: 1.3rem; margin-bottom: 0.75rem; }

      .transcript-toggle {
        max-width: 720px; margin: 0 auto;
      }
      .transcript-toggle summary {
        cursor: pointer; font-size: 1.1rem; font-weight: 700;
        padding: 0.75rem 0; color: var(--accent);
        list-style: none;
      }
      .transcript-toggle summary::-webkit-details-marker { display: none; }
      .transcript-toggle summary::before { content: '+ '; }
      .transcript-toggle[open] summary::before { content: '- '; }
      .transcript-text {
        line-height: 1.7; font-size: 1rem; white-space: pre-wrap;
        border-top: 1px solid rgb(var(--gray-light));
        padding-top: 1rem; margin-top: 0.5rem;
      }

      .back-link {
        display: inline-block; margin-bottom: 1rem; font-size: 0.9rem;
        color: var(--accent); text-decoration: none;
      }
      .back-link:hover { text-decoration: underline; }

      .feed-cta {
        max-width: 720px; margin: 2rem auto 0;
        text-align: center; padding: 1.5rem;
        background: rgba(var(--gray-light), 0.3);
        border-radius: 12px; font-size: 0.95rem;
      }
      .feed-cta a { color: var(--accent); }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div style="max-width: 720px; margin: 0 auto;">
        <a href="/episodes" class="back-link">&larr; All episodes</a>
      </div>

      <div class="ep-header">
        <h1>{episode.title}</h1>
        <p class="ep-meta">
          {formatDate(episode.pubDate)} · {formatDuration(episode.duration)} · {Math.round(episode.fileSize / 1024 / 1024 * 10) / 10} MB
        </p>
        <div class="category-tags">
          {episode.categories.map(cat => (
            <span class="category-tag">{cat}</span>
          ))}
        </div>
      </div>

      <div class="audio-player">
        <audio controls preload="metadata" src={`/api/episodes/${episode.filename}`}></audio>
      </div>

      <div class="show-notes">
        <h2>Show Notes</h2>
        {showNotes}
      </div>

      {episode.script && (
        <details class="transcript-toggle">
          <summary>Full Transcript</summary>
          <div class="transcript-text">{episode.script}</div>
        </details>
      )}

      <div class="feed-cta">
        Subscribe in your favorite podcast app: <a href="/api/feed.xml">RSS Feed</a>
      </div>
    </main>
    <Footer />
  </body>
</html>
