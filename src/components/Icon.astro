---
import { icon } from "../lib/icons";

interface Props {
	name: string;
	size?: number;
	class?: string;
	label?: string;
}

const { name, size = 24, class: klass = "", label } = Astro.props;
const svg = icon(name, size);
---

<span class={`hicon ${klass}`} aria-hidden={label ? undefined : "true"} aria-label={label} set:html={svg}></span>

<style>
.hicon { display: inline-flex; align-items: center; justify-content: center; line-height: 0; }
</style>
