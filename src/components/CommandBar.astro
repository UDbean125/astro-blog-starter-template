---
import Icon from "./Icon.astro";
---

<dialog class="cmd-dialog" data-cmd-dialog aria-label="Search & commands">
	<div class="cmd-inner">
		<div class="cmd-input-row">
			<Icon name="search" size={22} />
			<input
				class="cmd-input"
				data-cmd-input
				type="search"
				placeholder="Search your library or type a command…"
				autocomplete="off"
				spellcheck="false"
			/>
			<kbd class="kbd">Esc</kbd>
		</div>
		<div class="cmd-results" data-cmd-results role="listbox"></div>
		<div class="cmd-foot small mute">
			<span><kbd class="kbd">↑↓</kbd> navigate</span>
			<span><kbd class="kbd">↵</kbd> open</span>
			<span><kbd class="kbd">⌘K</kbd> toggle</span>
		</div>
	</div>
</dialog>

<style>
.cmd-dialog {
	padding: 0;
	border: 0;
	background: transparent;
	color: inherit;
	max-width: 640px;
	width: 100%;
	margin: 10vh auto auto;
}
.cmd-dialog::backdrop { background: rgba(6,21,48,0.5); backdrop-filter: blur(2px); }
.cmd-inner {
	background: var(--surface);
	border-radius: var(--radius-xl);
	box-shadow: var(--shadow-lg);
	border: 1px solid var(--border);
	overflow: hidden;
}
.cmd-input-row {
	display: flex; align-items: center; gap: 12px;
	padding: 14px 18px;
	border-bottom: 1px solid var(--border);
}
.cmd-input-row .hicon { color: var(--text-muted); }
.cmd-input {
	flex: 1;
	border: 0;
	background: transparent;
	font: inherit;
	font-size: 1.125rem;
	color: var(--text);
}
.cmd-input:focus { outline: none; }
.cmd-results {
	max-height: 58vh;
	overflow: auto;
	padding: 8px;
}
.cmd-foot {
	display: flex; gap: 20px; padding: 10px 18px;
	border-top: 1px solid var(--border);
	background: var(--bg-sunken);
}
.cmd-foot .kbd { background: var(--surface); padding: 1px 6px; border-radius: 4px; font-size: 0.7rem; }

.cmd-item {
	display: flex; align-items: center; gap: 14px;
	padding: 10px 12px;
	border-radius: var(--radius-md);
	cursor: pointer;
	color: var(--text);
}
.cmd-item:hover, .cmd-item[aria-selected="true"] { background: var(--surface-alt); }
.cmd-item img { width: 40px; height: 40px; object-fit: cover; border-radius: 6px; background: var(--surface-alt); }
.cmd-item .cmd-title { font-weight: 700; font-size: var(--fs-md); }
.cmd-item .cmd-sub { font-size: var(--fs-sm); color: var(--text-muted); }
.cmd-item .cmd-main { flex: 1; min-width: 0; }
.cmd-item .cmd-main > * { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cmd-group { padding: 6px 10px; font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-subtle); font-weight: 700; }
.cmd-empty { padding: 28px 20px; text-align: center; color: var(--text-muted); }
</style>
